@startuml create-user-sequence
!theme plain
title Figure 2.2.3. Create User – Sequence Diagram

skinparam shadowing false
skinparam backgroundColor white
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #546E7A
skinparam sequenceParticipantBackgroundColor #FFF8E1
skinparam sequenceLifeLineBorderColor #90A4AE
skinparam sequenceActorBorderColor #546E7A

actor "Admin / Manager" as admin
participant "UserFormPage" as page
participant "userApi" as api
participant "UserController" as ctrl
participant "UserModel" as um
participant "bcryptjs" as bcrypt
database "MongoDB" as db

admin -> page : Fill user form\n(name, email, password, role)
activate page

page -> api : createUser({ name, email, password, role })
activate api

api -> ctrl : POST /api/admin/users
activate ctrl

ctrl -> um : findOne({ email })
activate um
um -> db : Query by email
activate db
db --> um : Existing user or null
deactivate db
um --> ctrl : existingUser
deactivate um

alt Email already exists
  ctrl --> api : 400 { message: "Email already exists" }
  api --> page : Error response
  page --> admin : Display "Email already exists"
else Email unique
  ctrl -> bcrypt : genSalt(10)
  activate bcrypt
  bcrypt --> ctrl : salt
  ctrl -> bcrypt : hash(password, salt)
  bcrypt --> ctrl : passwordHash
  deactivate bcrypt

  ctrl -> um : create({ name, email, passwordHash,\nrole, isActive: true })
  activate um
  um -> db : Insert user document
  activate db
  db --> um : Created user
  deactivate db
  um --> ctrl : user
  deactivate um

  alt Validation error
    ctrl --> api : 400 { validation errors }
    api --> page : Error
    page --> admin : Display validation errors
  else Success
    ctrl --> api : 201 { success: true, data: user }
    deactivate ctrl
    api --> page : Created user data
    deactivate api

    page --> admin : Show success message\nRedirect to user list
    deactivate page
  end
end

@enduml
