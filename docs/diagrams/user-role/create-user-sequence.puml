@startuml
skinparam backgroundColor #FFFFFF
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true

actor "Admin" as Admin
participant "Controller\nUserController" as Controller
participant "Model\nUserModel" as Model
database "MongoDB" as DB

Admin -> Controller : 1: request to create new user\nPOST /api/admin/users\n{ name, email, password, role, isActive }
activate Controller

alt [requester_is_manager]
    Controller -> Controller : 2: check target role is Teacher or Student only
    alt [target_role_is_admin_or_manager]
        Controller --> Admin : 3: return 403 Forbidden\n(Manager cannot create Admin/Manager)
    end
end

Controller -> Model : 4: find user by email to check duplicate
activate Model
Model -> DB : 5: execute query by email
activate DB
DB --> Model : 6: return result
deactivate DB
Model --> Controller : 7: return existing user or null
deactivate Model

alt [email_already_exists]
    Controller --> Admin : 8: return 400 Bad Request\n(Email already exists)
else [email_available]
    Controller -> Model : 9: create new user with provided data
    activate Model
    Model -> DB : 10: insert user document
    activate DB
    DB --> Model : 11: return new user document
    deactivate DB
    Model --> Controller : 12: return created user object
    deactivate Model

    Controller -> Controller : 13: remove password from response object

    Controller --> Admin : 14: return 201 Created with user data
end

deactivate Controller

@enduml
