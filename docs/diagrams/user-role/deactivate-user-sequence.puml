@startuml deactivate-user-sequence
!theme plain
title Figure 2.2.5. Deactivate User – Sequence Diagram

skinparam shadowing false
skinparam backgroundColor white
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #546E7A
skinparam sequenceParticipantBackgroundColor #FFF8E1
skinparam sequenceLifeLineBorderColor #90A4AE
skinparam sequenceActorBorderColor #546E7A

actor "Admin / Manager" as admin
participant "UserListPage" as page
participant "ConfirmModal" as modal
participant "userApi" as api
participant "UserController" as ctrl
participant "UserModel" as um
database "MongoDB" as db

admin -> page : Click "Xóa" / Delete button
activate page

page -> modal : Show confirmation dialog\n"Bạn có chắc muốn xóa?"
activate modal
admin -> modal : Confirm deletion
modal --> page : onConfirm()
deactivate modal

page -> api : deleteUser(id)
activate api

api -> ctrl : DELETE /api/admin/users/:id
activate ctrl

ctrl -> um : findById(id)
activate um
um -> db : Query user by _id
activate db
db --> um : User document or null
deactivate db
um --> ctrl : user
deactivate um

alt User not found
  ctrl --> api : 404 { message: "User not found" }
  api --> page : Error
  page --> admin : Display "User not found"
else User found
  ctrl -> um : findByIdAndDelete(id)
  activate um
  um -> db : Delete user document
  activate db
  db --> um : Deleted
  deactivate db
  um --> ctrl : success
  deactivate um

  ctrl --> api : 200 { success: true }
  deactivate ctrl
  api --> page : Success
  deactivate api

  page -> page : Refresh user list
  page --> admin : Show success toast\nUser removed from list
  deactivate page
end

note over ctrl
  Note: Current implementation uses
  hard delete (findByIdAndDelete).
  Future: Consider soft delete
  (set isActive = false)
end note

@enduml
