@startuml
actor AdminManager as Admin
boundary "React UI" as UI
control "AuthMiddleware" as Auth
control "RoleMiddleware" as Role
control "UserController" as Controller
entity "User" as Model
database "MongoDB" as DB

Admin -> UI : Edit user details\nClick Save
UI -> Auth : PUT /api/admin/users/:id\n{ name, role, isActive }
Auth -> Auth : protect
Auth -> Role : requireRole('Admin', 'Manager')
Role -> Controller : Authorized
Controller -> Model : findById(req.params.id)
Model -> DB : Query
DB --> Model : targetUser
alt User not found
    Controller --> UI : 404 Not Found
else User found
    alt Role is Manager
        Controller -> Controller : Check targetUser.role
        alt targetUser is Admin/Manager OR new role is Admin/Manager
            Controller --> UI : 403 Forbidden
            UI --> Admin : Show error message
        end
    end
    Controller -> Model : Update allowed fields
    Controller -> Model : save()
    Model -> DB : Update document
    DB --> Model : Updated document
    Controller -> Controller : delete userObj.password
    Controller --> UI : 200 OK\n{ data: userObj }
    UI --> Admin : Show success, Update list
end
@enduml
