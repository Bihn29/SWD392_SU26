@startuml update-user-sequence
!theme plain
title Figure 2.2.4. Update User – Sequence Diagram

skinparam shadowing false
skinparam backgroundColor white
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #546E7A
skinparam sequenceParticipantBackgroundColor #FFF8E1
skinparam sequenceLifeLineBorderColor #90A4AE
skinparam sequenceActorBorderColor #546E7A

actor "Admin / Manager" as admin
participant "UserFormPage" as page
participant "userApi" as api
participant "UserController" as ctrl
participant "UserModel" as um
database "MongoDB" as db

admin -> page : Edit user form\n(name, role, isActive)
activate page

page -> api : updateUser(id, { name, role, isActive })
activate api

api -> ctrl : PUT /api/admin/users/:id
activate ctrl

ctrl -> um : findById(id)
activate um
um -> db : Query user by _id
activate db
db --> um : User document or null
deactivate db
um --> ctrl : user
deactivate um

alt User not found
  ctrl --> api : 404 { message: "User not found" }
  api --> page : Error
  page --> admin : Display "User not found"
else User found
  ctrl -> ctrl : Update allowed fields:\nname, role, isActive
  ctrl -> um : user.save()
  activate um
  um -> db : Update user document
  activate db
  db --> um : Updated user
  deactivate db
  um --> ctrl : updatedUser
  deactivate um

  ctrl --> api : 200 { success: true, data: user }
  deactivate ctrl
  api --> page : Updated user data
  deactivate api

  page --> admin : Show success message\nRedirect to user list
  deactivate page
end

@enduml
