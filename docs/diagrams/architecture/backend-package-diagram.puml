@startuml backend-package-diagram
!theme plain
title Figure 1.2.2. Back-end Package Diagram

skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam backgroundColor white
skinparam defaultFontSize 11
hide circle

skinparam package {
  BackgroundColor #FFFDE7
  BorderColor #546E7A
  FontSize 13
}

package "server/src" {

  package "config" as cfg {
    [db.js]
  }

  package "routes" as routes {
    [authRoutes]
    [subjectRoutes]
    [userRoutes]
    [lessonRoutes]
    [roleRoutes]
    [dashboardRoutes]
    [registrationRoutes]
  }

  package "middlewares" as mw {
    [authMiddleware]
    [roleMiddleware]
    [errorMiddleware]
  }

  package "validations" as val {
    [subjectValidation]
    [roleValidation]
  }

  package "controllers" as ctrl {
    [authController]
    [subjectController]
    [userController]
    [lessonController]
    [roleController]
    [dashboardController]
    [registrationController]
  }

  package "services" as svc {
    [subjectService]
    [roleService]
  }

  package "models" as mdl {
    [User]
    [Subject]
    [Lesson]
    [Role]
    [Registration]
  }

  package "constants" as cnst {
    [permissions]
  }

  package "scripts" as scr {
    [seed.js]
    [seedRoles.js]
    [generateSeed.js]
  }

  package "data" as dt {
    [seed.vi.json]
    [roleSeed.vi.json]
  }

  [app.js]
  [server.js]
}

database "MongoDB" as mongodb

' ── Relationships ──
[server.js] --> [app.js]
[server.js] --> [db.js]
[app.js] --> routes
routes --> mw : middleware chain
routes --> ctrl
routes --> val
ctrl --> svc : delegate logic
ctrl --> mdl : direct query
svc --> mdl : Mongoose operations
mdl --> mongodb : ODM
[db.js] --> mongodb : Connection

scr --> dt : read seed data
scr --> mdl : insert records
[roleMiddleware] ..> [permissions] : check permissions

@enduml
