@startuml dashboard-class-diagram
!theme plain
title Figure 2.3.1. Dashboard Management – Class Diagram

skinparam shadowing false
skinparam linetype ortho
skinparam packageStyle rectangle
skinparam classAttributeIconSize 0
skinparam backgroundColor white
skinparam defaultFontSize 11
hide circle

skinparam class {
  BackgroundColor #FFF8E1
  BorderColor #546E7A
  ArrowColor #546E7A
}

package "Frontend – Dashboard" {

  class DashboardPage {
    - stats: Object
    - detailData: Array
    - selectedType: string
    - loading: boolean
    - detailLoading: boolean
    + fetchOverview()
    + fetchDetails(type)
    + handleCardClick(type)
    + renderStatCards()
    + renderDetailTable()
  }

  class dashboardApi <<API Service>> {
    + getDashboardOverview(): Promise
    + getDashboardDetails(type): Promise
  }
}

package "Backend – Dashboard" {

  class DashboardController <<Controller>> {
    + getOverview(req, res)
    + getDetails(req, res)
  }

  class UserModel <<Model>> {
    + countDocuments(filter)
    + find(filter)
  }

  class SubjectModel <<Model>> {
    + countDocuments(filter)
    + find(filter)
  }

  class LessonModel <<Model>> {
    + countDocuments()
    + find(filter)
  }

  class RegistrationModel <<Model>> {
    + countDocuments(filter)
  }

  class AuthMiddleware <<Middleware>> {
    + protect(req, res, next)
  }

  class "authorizeRoles" as RoleCheck <<Middleware>> {
    + ('Admin', 'Manager')
  }
}

' ── Frontend ──
DashboardPage --> dashboardApi : fetch data

' ── Backend ──
DashboardController --> UserModel : count/query users
DashboardController --> SubjectModel : count/query subjects
DashboardController --> LessonModel : count/query lessons
DashboardController --> RegistrationModel : count registrations

AuthMiddleware ..> DashboardController : protect
RoleCheck ..> DashboardController : authorize

' ── Cross-layer ──
dashboardApi ..> DashboardController : REST API

note bottom of DashboardController
  Overview Stats:
  totalUsers, totalAdmins,
  totalManagers, totalTeachers,
  totalStudents, totalSubjects,
  publishedSubjects, draftSubjects,
  totalLessons, totalEnrolledStudents

  Detail Types:
  users, admins, managers,
  teachers, students, subjects,
  publishedSubjects, draftSubjects,
  lessons, enrolledStudents
end note

@enduml
