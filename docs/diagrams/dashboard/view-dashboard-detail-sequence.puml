@startuml view-dashboard-detail-sequence
!theme plain
title Figure 2.3.3. View Dashboard Detail – Sequence Diagram

skinparam shadowing false
skinparam backgroundColor white
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #546E7A
skinparam sequenceParticipantBackgroundColor #FFF8E1
skinparam sequenceLifeLineBorderColor #90A4AE
skinparam sequenceActorBorderColor #546E7A

actor "Admin / Manager" as admin
participant "DashboardPage" as page
participant "dashboardApi" as api
participant "DashboardController" as ctrl
participant "UserModel" as um
participant "SubjectModel" as sm
participant "LessonModel" as lm
participant "RegistrationModel" as rm
database "MongoDB" as db

admin -> page : Click on statistic card\n(e.g., "Tổng học viên")
activate page

page -> page : Set selectedType = "students"
page -> api : getDashboardDetails("students")
activate api

api -> ctrl : GET /api/admin/dashboard/details?type=students
activate ctrl

alt type === "users"
  ctrl -> um : find().select('-password').sort({createdAt: -1})
  um -> db : Query all users
  db --> um : users[]
  um --> ctrl : items
else type === "admins" | "managers" | "teachers" | "students"
  ctrl -> um : find({role: type}).select('-password')
  um -> db : Query users by role
  db --> um : filtered users[]
  um --> ctrl : items
else type === "subjects" | "publishedSubjects" | "draftSubjects"
  ctrl -> sm : find(filter).populate('owner', 'name')
  sm -> db : Query subjects
  db --> sm : subjects[]
  sm --> ctrl : items
else type === "lessons"
  ctrl -> lm : find().populate('subject', 'name')
  lm -> db : Query lessons
  db --> lm : lessons[]
  lm --> ctrl : items
else type === "enrolledStudents"
  ctrl -> rm : find({registrationStatus: 'Approved'})\n.populate('student').populate('subject')
  rm -> db : Query registrations
  db --> rm : registrations[]
  rm --> ctrl : items
else Invalid type
  ctrl --> api : 400 { message: "Loại dữ liệu không hợp lệ" }
  api --> page : Error
  page --> admin : Display error
end

ctrl --> api : 200 { success: true, data: items }
deactivate ctrl
api --> page : Detail data array
deactivate api

page --> admin : Render detail table\nfor selected type
deactivate page

@enduml
