@startuml view-course-detail-sequence
!theme plain
title Figure 2.4.3. View Course Detail – Sequence Diagram

skinparam shadowing false
skinparam backgroundColor white
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #546E7A
skinparam sequenceParticipantBackgroundColor #FFF8E1
skinparam sequenceLifeLineBorderColor #90A4AE
skinparam sequenceActorBorderColor #546E7A

actor "Admin / Manager" as admin
participant "SubjectDetailPage" as page
participant "subjectApi" as api
participant "lessonApi" as lapi
participant "SubjectController" as ctrl
participant "SubjectService" as svc
participant "SubjectModel" as sm
participant "LessonController" as lctrl
participant "LessonModel" as lm
database "MongoDB" as db

admin -> page : Navigate to /admin/subjects/:id
activate page

page -> api : getSubjectById(id)
activate api

api -> ctrl : GET /api/subjects/:id
activate ctrl

ctrl -> svc : getSubjectById(id)
activate svc

svc -> sm : findById(id)\n.populate('owner')\n.populate('createdBy')\n.populate('updatedBy')
activate sm
sm -> db : Query subject by _id
activate db
db --> sm : Subject document
deactivate db
sm --> svc : subject
deactivate sm

svc --> ctrl : subject
deactivate svc

alt Subject not found
  ctrl --> api : 404 { message: "Subject not found" }
  api --> page : Error
  page --> admin : Display "Subject not found"
else Subject found
  ctrl --> api : 200 { data: subject }
  deactivate ctrl
  api --> page : Subject data
  deactivate api

  page --> admin : Render subject detail\n(name, category, owner, status,\ndescription, thumbnail)

  == User clicks "Bài học" tab ==

  admin -> page : Click "Bài học" tab
  page -> lapi : getLessonsBySubject(subjectId)
  activate lapi

  lapi -> lctrl : GET /api/admin/subjects/:subjectId/lessons
  activate lctrl

  lctrl -> lm : find({ subject: subjectId })\n.sort({ order: 1 })\n.populate('createdBy')\n.populate('updatedBy')
  activate lm
  lm -> db : Query lessons by subject
  activate db
  db --> lm : lessons[]
  deactivate db
  lm --> lctrl : lessons
  deactivate lm

  lctrl --> lapi : 200 { data: lessons }
  deactivate lctrl
  lapi --> page : Lessons array
  deactivate lapi

  page --> admin : Render lessons tab\n(title, type, order, status, actions)
  deactivate page
end

@enduml
