@startuml create-course-sequence
!theme plain
title Figure 2.4.4. Create Course – Sequence Diagram

skinparam shadowing false
skinparam backgroundColor white
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #546E7A
skinparam sequenceParticipantBackgroundColor #FFF8E1
skinparam sequenceLifeLineBorderColor #90A4AE
skinparam sequenceActorBorderColor #546E7A

actor "Admin" as admin
participant "SubjectCreatePage" as page
participant "SubjectForm" as form
participant "subjectApi" as api
participant "SubjectValidation" as val
participant "SubjectController" as ctrl
participant "SubjectService" as svc
participant "SubjectModel" as sm
database "MongoDB" as db

admin -> page : Navigate to /admin/subjects/create
activate page
page -> form : Render SubjectForm (mode=create)
activate form

admin -> form : Fill form\n(name, category, owner,\nthumbnail, description, featured)

form -> form : Client-side validation
form -> api : createSubject(formData)
activate api

api -> val : POST /api/subjects [body: formData]
activate val

alt Validation failed
  val --> api : 400 { validation errors }
  api --> form : Error
  form --> admin : Display validation errors
else Validation passed
  val -> ctrl : next()
  deactivate val
  activate ctrl

  ctrl -> svc : createSubject(data, req.user._id)
  activate svc

  svc -> sm : create({ ...data,\ncreatedBy: userId, updatedBy: userId })
  activate sm
  sm -> db : Insert subject document
  activate db
  db --> sm : Created subject
  deactivate db
  sm --> svc : subject
  deactivate sm

  svc -> sm : findById(subject._id)\n.populate('owner', 'name email role')
  activate sm
  sm -> db : Query with populate
  db --> sm : Populated subject
  deactivate sm

  svc --> ctrl : populated subject
  deactivate svc

  ctrl --> api : 201 { message: "Subject created successfully",\ndata: subject }
  deactivate ctrl
  api --> form : Success response
  deactivate api

  form --> page : Navigate to subject list
  deactivate form
  page --> admin : Show success toast\nRedirect to /admin/subjects
  deactivate page
end

note over svc
  Default status: "Draft"
  Owner must be a valid User _id
end note

@enduml
