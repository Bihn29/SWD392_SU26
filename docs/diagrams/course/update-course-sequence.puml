@startuml update-course-sequence
!theme plain
title Figure 2.4.5. Update Course – Sequence Diagram

skinparam shadowing false
skinparam backgroundColor white
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #546E7A
skinparam sequenceParticipantBackgroundColor #FFF8E1
skinparam sequenceLifeLineBorderColor #90A4AE
skinparam sequenceActorBorderColor #546E7A

actor "Admin / Manager" as admin
participant "SubjectEditPage" as page
participant "SubjectForm" as form
participant "subjectApi" as api
participant "SubjectController" as ctrl
participant "SubjectService" as svc
participant "SubjectModel" as sm
database "MongoDB" as db

admin -> page : Navigate to /admin/subjects/:id/edit
activate page

page -> api : getSubjectById(id)
activate api
api -> ctrl : GET /api/subjects/:id
ctrl -> svc : getSubjectById(id)
svc -> sm : findById(id).populate(...)
sm -> db : Query subject
db --> sm : subject
sm --> svc : subject
svc --> ctrl : subject
ctrl --> api : 200 { data: subject }
api --> page : Subject data
deactivate api

page -> form : Render SubjectForm\n(mode=edit, initialData=subject)
activate form

admin -> form : Edit form fields
form -> api : updateSubject(id, formData)
activate api

api -> ctrl : PUT /api/subjects/:id [body: formData]
activate ctrl

ctrl -> svc : updateSubject(id, data, req.user)
activate svc

svc -> sm : findById(id)
activate sm
sm -> db : Query subject
db --> sm : subject
deactivate sm

alt Subject not found
  svc --> ctrl : null
  ctrl --> api : 404 { message: "Subject not found" }
  api --> form : Error
  form --> admin : Display "Subject not found"
else Expert updating non-assigned subject
  svc --> ctrl : throw 403 error
  ctrl --> api : 403 { message: "You can only update\nsubjects assigned to you" }
  api --> form : Error
  form --> admin : Display permission error
else Valid update
  svc -> svc : Object.assign(subject, data)\nsubject.updatedBy = user._id
  svc -> sm : subject.save()
  activate sm
  sm -> db : Update document
  db --> sm : Updated subject
  deactivate sm

  svc -> sm : findById().populate(...)
  sm -> db : Populated query
  db --> sm : Populated subject
  sm --> svc : subject

  svc --> ctrl : updated subject
  deactivate svc

  ctrl --> api : 200 { message: "Subject updated successfully",\ndata: subject }
  deactivate ctrl
  api --> form : Success response
  deactivate api

  form --> admin : Show success toast\nRedirect to subject detail
  deactivate form
  deactivate page
end

@enduml
