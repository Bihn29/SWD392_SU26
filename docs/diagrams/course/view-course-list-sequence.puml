@startuml view-course-list-sequence
!theme plain
title Figure 2.4.2. View Course List – Sequence Diagram

skinparam shadowing false
skinparam backgroundColor white
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #546E7A
skinparam sequenceParticipantBackgroundColor #FFF8E1
skinparam sequenceLifeLineBorderColor #90A4AE
skinparam sequenceActorBorderColor #546E7A

actor "Admin / Manager" as admin
participant "SubjectListPage" as page
participant "subjectApi" as api
participant "SubjectController" as ctrl
participant "SubjectService" as svc
participant "SubjectModel" as sm
participant "RegistrationModel" as rm
database "MongoDB" as db

admin -> page : Navigate to /admin/subjects\n(with optional filters)
activate page

page -> api : getSubjects({ page, limit,\nsearch, category, status })
activate api

api -> ctrl : GET /api/subjects?page=1&limit=10&...
activate ctrl

ctrl -> ctrl : Check req.user.role\nSet excludeInactive for non-Admin

ctrl -> svc : getSubjects({ page, limit,\nsearch, category, status,\nexcludeInactive })
activate svc

svc -> svc : Build filter object\n(search, category, status, owner)

svc -> sm : find(filter).populate('owner')\n.sort(sortField).skip().limit()
activate sm
sm -> db : Query subjects with filter
activate db
db --> sm : subjects[]
deactivate db
sm --> svc : items
deactivate sm

svc -> sm : countDocuments(filter)
activate sm
sm -> db : Count matching documents
db --> sm : totalItems
deactivate sm

svc -> rm : countDocuments({subject, status:'Approved'})\nfor each subject
activate rm
rm -> db : Count students per subject
db --> rm : studentCount per subject
deactivate rm

svc --> ctrl : { items: [...], pagination: { page, limit,\ntotalItems, totalPages } }
deactivate svc

ctrl --> api : 200 { data: items, pagination }
deactivate ctrl
api --> page : Subjects + pagination
deactivate api

page --> admin : Render subject table\n(name, category, owner, status,\nstudentCount, actions)
deactivate page

@enduml
