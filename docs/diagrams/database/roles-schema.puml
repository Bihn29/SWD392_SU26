@startuml roles-schema
!theme plain
title Figure 3.2. Roles Collection – Schema Detail

skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam backgroundColor white
skinparam defaultFontSize 12
hide circle

skinparam class {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  HeaderBackgroundColor #1565C0
  HeaderFontColor white
}

class "roles" <<MongoDB Collection>> {
  .. Primary Key ..
  **_id** : ObjectId <<auto-generated>>
  .. Required Fields ..
  **name** : String [required, maxlength: 100]
  **code** : String [required, unique]
  .. Optional Fields ..
  description : String [maxlength: 500, default: ""]
  permissions : String[] [default: []]
  .. Status ..
  status : String [enum: "Active" | "Inactive", default: "Active"]
  .. System Flag ..
  isSystemRole : Boolean [default: false]
  .. Audit Fields ..
  createdBy : ObjectId → users [optional]
  updatedBy : ObjectId → users [optional]
  .. Timestamps ..
  createdAt : Date [auto]
  updatedAt : Date [auto]
}

note right of "roles"
  **Indexes:**
  - code: unique index
  - status: regular index

  **System Roles (isSystemRole = true):**
  - Admin
  - Manager
  - Teacher
  - Student

  **Permissions example:**
  ["manage_users", "manage_subjects",
   "manage_lessons", "view_dashboard",
   "manage_roles"]
end note

@enduml
