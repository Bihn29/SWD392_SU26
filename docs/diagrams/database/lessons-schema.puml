@startuml lessons-schema
!theme plain
title Figure 3.5. Lessons Collection – Schema Detail

skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam backgroundColor white
skinparam defaultFontSize 12
hide circle

skinparam class {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  HeaderBackgroundColor #1565C0
  HeaderFontColor white
}

class "lessons" <<MongoDB Collection>> {
  .. Primary Key ..
  **_id** : ObjectId <<auto-generated>>
  .. Required Fields ..
  **subject** : ObjectId → subjects [required, ref: "Subject"]
  **title** : String [required, "Vui lòng nhập tên bài học"]
  **type** : String [enum: "Video" | "HTML" | "Quiz", required]
  **order** : Number [required, default: 1]
  .. Type-specific Content ..
  videoUrl : String [required if type = "Video"]
  htmlContent : String [required if type = "HTML"]
  .. Status ..
  status : String [enum: "Active" | "Inactive", default: "Active"]
  .. Audit Fields ..
  createdBy : ObjectId → users [ref: "User"]
  updatedBy : ObjectId → users [ref: "User"]
  .. Timestamps ..
  createdAt : Date [auto]
  updatedAt : Date [auto]
}

note right of "lessons"
  **Content by Type:**
  ┌─────────┬──────────────────────┐
  │ Type    │ Required Field       │
  ├─────────┼──────────────────────┤
  │ Video   │ videoUrl             │
  │ HTML    │ htmlContent          │
  │ Quiz    │ (future development) │
  └─────────┴──────────────────────┘

  **Soft Delete:**
  - DELETE sets status = "Inactive"
  - Can re-activate via PATCH /:id/activate

  **Ordering:**
  - Lessons sorted by 'order' field
  - Displayed in ascending order within subject
end note

@enduml
