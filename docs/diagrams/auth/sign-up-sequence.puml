@startuml sign-up-sequence
!theme plain
title Figure 2.1.3. Sign Up – Sequence Diagram

skinparam shadowing false
skinparam backgroundColor white
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #546E7A
skinparam sequenceParticipantBackgroundColor #FFF8E1
skinparam sequenceLifeLineBorderColor #90A4AE
skinparam sequenceActorBorderColor #546E7A

actor "User" as user
participant "RegisterPage" as rp
participant "authApi" as api
participant "AuthController" as ctrl
participant "UserModel" as um
participant "bcryptjs" as bcrypt
database "MongoDB" as db

user -> rp : Fill registration form\n(fullName, email, password, phone)
activate rp

rp -> api : register({ fullName, email, password, phone })
activate api

api -> ctrl : POST /api/auth/register
activate ctrl

ctrl -> um : findOne({ email })
activate um
um -> db : Query users by email
activate db
db --> um : Existing user (or null)
deactivate db
um --> ctrl : existingUser
deactivate um

alt Email already exists
  ctrl --> api : 400 { message: "Email đã tồn tại" }
  api --> rp : Error response
  rp --> user : Display "Email đã tồn tại"
else Email is unique
  ctrl -> bcrypt : genSalt(10)
  activate bcrypt
  bcrypt --> ctrl : salt
  ctrl -> bcrypt : hash(password, salt)
  bcrypt --> ctrl : passwordHash
  deactivate bcrypt

  ctrl -> um : create({ name: fullName, email,\npasswordHash, role: 'Student' })
  activate um
  um -> db : Insert new user document
  activate db
  db --> um : Created user
  deactivate db
  um --> ctrl : user
  deactivate um

  alt Validation error
    ctrl --> api : 400 { validation errors }
    api --> rp : Error response
    rp --> user : Display validation errors
  else Registration success
    ctrl --> api : 201 { message: "Đăng ký tài khoản thành công.\nVui lòng đăng nhập." }
    deactivate ctrl
    api --> rp : Success response
    deactivate api

    rp -> rp : navigate('/login')
    rp --> user : Redirect to Login page\nwith success message
    deactivate rp
  end
end

note over ctrl
  Default role: "Student"
  Password stored as bcrypt hash
end note

@enduml
