@startuml role-redirect-sequence
!theme plain
title Figure 2.1.4. Role-based Redirect – Sequence Diagram

skinparam shadowing false
skinparam backgroundColor white
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #546E7A
skinparam sequenceParticipantBackgroundColor #FFF8E1
skinparam sequenceLifeLineBorderColor #90A4AE
skinparam sequenceActorBorderColor #546E7A

actor "User" as user
participant "LoginPage /\nGuestRoute" as page
participant "AuthContext" as ac
participant "roleRedirect" as rd
participant "React Router" as router

user -> page : Login successful /\nAccess authenticated page
activate page

page -> ac : useAuth() → { user }
activate ac
ac --> page : user object with role
deactivate ac

page -> rd : getRedirectPathByRole(user)
activate rd

rd -> rd : getRoleCode(user)

note right of rd
  getRoleCode checks:
  1. typeof user.role === 'string' → return role
  2. user.role?.code → return code
  3. user.role?.name → return name
  4. else → return null
end note

alt roleCode === "Admin"
  rd --> page : "/admin"
else roleCode === "Manager"
  rd --> page : "/admin"
else roleCode === "Teacher"
  rd --> page : "/teacher"
else roleCode === "Student"
  rd --> page : "/my-courses"
else Unknown role
  rd --> page : "/"
end
deactivate rd

page -> router : navigate(redirectPath)
activate router
router --> user : Render target page
deactivate router
deactivate page

note over page, rd
  GuestRoute also uses this logic:
  If user is already authenticated,
  redirect away from /login and /register
end note

@enduml
