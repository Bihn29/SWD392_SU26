@startuml
actor TeacherAdmin as User
boundary "React UI" as UI
control "AuthMiddleware" as Auth
control "RoleOwnerMiddleware" as Role
control "LessonController" as Controller
entity "Lesson" as Model
database "MongoDB" as DB

User -> UI : Enter lesson details\nSelect type\nClick Create
UI -> Auth : POST /.../subjects/:subjectId/lessons\n{ title, type, order, videoUrl/htmlContent }
Auth -> Auth : protect
Auth -> Role : requireRole or checkCourseOwner
Role -> Controller : Authorized
Controller -> Model : create({ subject: subjectId, ..., createdBy, updatedBy })
Model -> Model : Mongoose Validation
alt Invalid data (e.g. wrong type enum)
    Model --> Controller : ValidationError
    Controller --> UI : 400 Bad Request
else Validation passed
    Model -> DB : Insert
    DB --> Model : New lesson document
    Model --> Controller : lesson
    Controller --> UI : 201 Created\n{ data: lesson }
    UI --> User : Show success, reload list
end
@enduml
