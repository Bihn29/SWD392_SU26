@startuml update-lesson-sequence
!theme plain
title Figure 2.5.4. Update Lesson – Sequence Diagram

skinparam shadowing false
skinparam backgroundColor white
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #546E7A
skinparam sequenceParticipantBackgroundColor #FFF8E1
skinparam sequenceLifeLineBorderColor #90A4AE
skinparam sequenceActorBorderColor #546E7A

actor "Admin / Manager" as admin
participant "SubjectLessonsTab" as tab
participant "lessonApi" as api
participant "LessonController" as ctrl
participant "LessonModel" as lm
database "MongoDB" as db

admin -> tab : Click "Sửa" on a lesson
activate tab

tab -> tab : Load lesson data into form\nShow edit form

admin -> tab : Modify fields and submit

tab -> api : updateLesson(lessonId,\n{ title, type, order, videoUrl, htmlContent })
activate api

api -> ctrl : PUT /api/admin/lessons/:id
activate ctrl

ctrl -> ctrl : data = { ...req.body,\nupdatedBy: req.user._id }

ctrl -> lm : findByIdAndUpdate(id, data,\n{ new: true, runValidators: true })
activate lm
lm -> db : Update lesson document
activate db

alt Lesson not found
  db --> lm : null
  lm --> ctrl : null
  ctrl --> api : 404 { message: "Lesson not found" }
  api --> tab : Error
  tab --> admin : Display "Lesson not found"
else Validation error
  db --> lm : ValidationError
  lm --> ctrl : Error
  ctrl --> api : 400 { validation errors }
  api --> tab : Error
  tab --> admin : Display validation errors
else Success
  db --> lm : Updated lesson
  deactivate db
  lm --> ctrl : lesson
  deactivate lm

  ctrl --> api : 200 { success: true, data: lesson,\nmessage: "Lesson updated successfully" }
  deactivate ctrl
  api --> tab : Updated lesson
  deactivate api

  tab -> tab : Refresh lessons list\nHide form
  tab --> admin : Show success toast\nLesson updated in list
  deactivate tab
end

@enduml
